@page "/"
@using System.Collections.Concurrent
@using System.Diagnostics
@using Allegro.Admin.Models
@implements IDisposable
@inject ToastService toastService
@inject Saver<SaveData> saveData
@inject AllegroPublishService allegro
@rendermode InteractiveServer

<PageTitle>Allegro parser</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Allegro parser</h1>
    <button class="btn btn-success" @onclick="SaveAllOptions">Save all options</button>
</div>

<div class="row g-3">

    <div class="col-12 col-xl-6">
        <div class="card h-100 shadow-sm">
            <div class="card-header fw-semibold">Last parsing</div>
            <div class="card-body">
                <div class="row text-center mb-3">
                    <div class="col">
                        <div class="fs-4 fw-bold">@_lastParsing.AllUrls.Count</div>
                        <div class="text-muted small">All urls</div>
                    </div>
                    <div class="col">
                        <div class="fs-4 fw-bold text-success">@_lastParsing.Products.Count</div>
                        <div class="text-muted small">Success</div>
                    </div>
                    <div class="col">
                        <div class="fs-4 fw-bold text-danger">@(_lastParsing.AllUrls.Count - _lastParsing.Products.Count) / @(_lastParsing.Products.Values.Count - _lastParsing.Products.Values.Where(CSVMaker.FilterProduct(SaverExtensions.CSVOptions.Read()).Invoke).Count())</div>
                        <div class="text-muted small">Failed / black list</div>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span class="small text-muted">Progress</span>
                    <span class="small text-muted">@_progressPercent%</span>
                </div>
                <div class="progress mb-3" role="progressbar" aria-valuenow="@_progressPercent" aria-valuemin="0" aria-valuemax="100">
                    <div class="progress-bar" style="width: @(_progressPercent)%"></div>
                </div>

                <span class="badge @(_isLastParseSuccess ? "bg-success" : "bg-warning text-dark")">
                    @(_isLastParseSuccess ? "Success" : $"Failure on {_lastParsing.CurrentIndexUrl}")
                </span>

                @if (_lastParsing.BlackListUrls.Count > 0)
                {
                    <details class="mt-3">
                        <summary class="small text-muted">Show failed / invalid urls (@_lastParsing.BlackListUrls.Count)</summary>
                        <ul class="small mt-2">
                            @foreach (var url in _lastParsing.BlackListUrls)
                            {
                                <li>@url</li>
                            }
                        </ul>
                    </details>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-6">
        <div class="card h-100 shadow-sm">
            <div class="card-header fw-semibold">CSV export</div>
            <div class="card-body">
                <div class="row g-3 mb-2">
                    <div class="col-6">
                        <label class="form-label" for="minProductCountInput">Minimal product count</label>
                        <input id="minProductCountInput" class="form-control" type="number" min="0" @bind="_csvOptions.MinimalProductCount" />
                        <div class="form-text">Categories with fewer parsed products than this are excluded from the CSV.</div>
                    </div>
                    <div class="col-6">
                        <label class="form-label" for="priceMultiplierInput">Price multiplier</label>
                        <input id="priceMultiplierInput" class="form-control" type="number" step="0.01" min="0" @bind="_csvOptions.MultiplierPrice" />
                        <div class="form-text">Multiplies the parsed price by this factor before writing it to the CSV.</div>
                    </div>
                    <div class="col-6">
                        <label class="form-label" for="minPriceInput">Minimal price</label>
                        <input id="minPriceInput" class="form-control" type="number" step="0.01" min="0" @bind="_csvOptions.MinimalPrice" />
                        <div class="form-text">Products priced below this value are excluded from the CSV.</div>
                    </div>
                    <div class="col-6">
                        <label class="form-label" for="categoryBlackListInput">Category black list</label>
                        <input id="categoryBlackListInput" class="form-control" type="text" @bind="CategoriesBlackListText" placeholder="e.g. Electronics, Toys" />
                        <div class="form-text">Comma-separated category names to exclude from the CSV.</div>
                    </div>
                </div>
                <div class="small text-muted mb-2">
                    These options are stored in <code>csv_options.txt</code> and control which parsed products are included when the CSV is (re)generated. Use <strong>Save all options</strong> above to persist changes.
                </div>
                <div class="d-flex gap-2">
                    <a class="btn btn-outline-primary" href="/@CSVMaker.FileName" download="@CSVMaker.FileName">Download products.csv</a>
                    <button class="btn btn-primary" @onclick="RegenerateCsv">Regenerate CSV</button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                <span>Console</span>
                <span class="badge @(isStartedConsole ? "bg-success" : "bg-secondary")">
                    @(isStartedConsole ? $"Running (PID {saveData.Value.StartedConsoleId})" : "Not running")
                </span>
            </div>
            <div class="card-body">
                <label class="form-label" for="pathDllInput">Path to console.dll</label>
                <input id="pathDllInput" class="form-control mb-1" type="text" @bind="@saveData.Value.PathDllConsole" placeholder="Path to console.dll" />
                <div class="form-text mb-3">Full path to the compiled <code>Allegro.Console.dll</code> file that will be launched by the buttons below.</div>

                <div class="d-flex flex-wrap gap-2 mb-2">
                    <button class="btn btn-primary" disabled="@isStartedConsole" @onclick="()=>StartConsole(saveData.Value.PathDllConsole,_consoleBaseStartOptions.Args)">Start parsing</button>
                    <button class="btn btn-outline-primary" disabled="@isStartedConsole" @onclick="()=>StartConsole(saveData.Value.PathDllConsole,_consoleBrowserOnlyOptions.Args)">Only Browser</button>
                    @if (isStartedConsole)
                    {
                        <button class="btn btn-danger ms-auto" @onclick="StopConsole">Stop console</button>
                    }
                </div>
                <div class="form-text mb-3">
                    <strong>Start parsing</strong> runs a full parse over the saved url list. <strong>Only Browser</strong> just opens/configures the browser without parsing, useful for logging in manually first.
                </div>

                <hr />

                <h6 class="fw-semibold">Advanced options</h6>
                <div class="row g-3 align-items-end mb-2">
                    <div class="col-12 col-md-3">
                        <label class="form-label" for="startIndexInput">Start index</label>
                        <input id="startIndexInput" class="form-control" type="number" @bind="_consoleAdvancedOptions.StartIndex" placeholder="Start from index [0 .. length]" />
                        <div class="form-text">Skips ahead and resumes parsing from this position in the url list instead of starting at 0.</div>
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="form-label" for="modeXmlSelect">Url source</label>
                        <select id="modeXmlSelect" class="form-select" @bind="_consoleAdvancedOptions.ModeXml">
                            <option value="none">Saved links</option>
                            <option value="new_parse">New parse links</option>
                            <option value="load_last_session">Continue last session</option>
                        </select>
                        <div class="form-text">Where the console reads the list of urls to parse from.</div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="form-check">
                            <input id="configureBrowserCheck" class="form-check-input" type="checkbox" @bind="_consoleAdvancedOptions.ConfigureBrowser" />
                            <label class="form-check-label" for="configureBrowserCheck">Only configure browser</label>
                        </div>
                        <div class="form-text">Opens the browser for setup (e.g. login) without running the parser.</div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="form-check">
                            <input id="isUserStartCheck" class="form-check-input" type="checkbox" @bind="_consoleAdvancedOptions.IsUserStart" />
                            <label class="form-check-label" for="isUserStartCheck">Manual start</label>
                        </div>
                        <div class="form-text">Waits for you to trigger parsing manually instead of starting automatically.</div>
                    </div>
                </div>
                <button class="btn btn-secondary" disabled="@isStartedConsole" @onclick="()=>StartConsole(saveData.Value.PathDllConsole,_consoleAdvancedOptions.Args)">Start advanced</button>
            </div>
        </div>
    </div>
    
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                <span>Console output</span>
                <button class="btn btn-sm btn-outline-secondary" @onclick="ClearLogs">Clear</button>
            </div>
            <div class="card-body">
                <pre class="bg-dark text-light p-3 rounded mb-2" style="max-height: 320px; overflow-y: auto; font-size: 0.8rem; white-space: pre-wrap;">@(_consoleLogs.IsEmpty ? "No output yet." : string.Join("\n", _consoleLogs))</pre>
                <div class="form-text">Live stdout/stderr from a console process started in this admin session. Output from processes started before the admin app last restarted isn't available.</div>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                <span>Publish to Allegro</span>
                <span class="badge @(allegro.Settings.IsConnected ? "bg-success" : "bg-secondary")">
                    @(allegro.Settings.IsConnected ? "Connected" : "Not connected")
                </span>
            </div>
            <div class="card-body">
                <div class="row g-3 mb-3">
                    <div class="col-12 col-md-5">
                        <label class="form-label" for="clientIdInput">Client ID</label>
                        <input id="clientIdInput" class="form-control" type="text" @bind="allegro.Settings.ClientId" />
                        <div class="form-text">Client ID of your app from <code>apps.developer.allegro.pl</code>.</div>
                    </div>
                    <div class="col-12 col-md-5">
                        <label class="form-label" for="clientSecretInput">Client Secret</label>
                        <input id="clientSecretInput" class="form-control" type="password" @bind="allegro.Settings.ClientSecret" />
                        <div class="form-text">Client Secret of the same app. Stored locally in <code>allegro_settings.txt</code>.</div>
                    </div>
                    <div class="col-6 col-md-2">
                        <label class="form-label" for="currencyInput">Currency</label>
                        <input id="currencyInput" class="form-control" type="text" @bind="allegro.Settings.Currency" />
                        <div class="form-text">e.g. PLN.</div>
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
                    <button class="btn btn-outline-secondary" @onclick="SaveAllOptions">Save credentials</button>
                    <button class="btn btn-outline-primary" @onclick="ConnectAllegro">@(allegro.Settings.IsConnected ? "Reconnect account" : "Connect account")</button>
                    <button class="btn btn-success" disabled="@(!allegro.Settings.IsConnected || allegro.IsPublishing)" @onclick="PublishToAllegro">
                        @(allegro.IsPublishing ? "Publishing..." : "Publish CSV to Allegro")
                    </button>
                </div>

                @if (_deviceInfo is not null)
                {
                    <div class="alert alert-info py-2 mb-2">
                        Open <a href="@_deviceInfo.VerificationUri" target="_blank">@_deviceInfo.VerificationUri</a>
                        and confirm the code <strong>@_deviceInfo.UserCode</strong>. This panel updates to
                        <em>Connected</em> once you approve.
                    </div>
                }

                <div class="form-text mb-3">
                    Reads <code>@CSVMaker.FileName</code> (EAN;Liczba;Cena) and updates <strong>price and stock</strong> on existing
                    offers. Offers are matched by their <strong>external ID = EAN</strong>. Products with no matching offer are skipped
                    (new offers are not created).
                </div>

                <pre class="bg-dark text-light p-3 rounded mb-0" style="max-height: 240px; overflow-y: auto; font-size: 0.8rem; white-space: pre-wrap;">@(allegro.Logs.Count == 0 ? "No publish activity yet." : string.Join("\n", allegro.Logs))</pre>
            </div>
        </div>
    </div>
</div>


@code{
    private ParseResponse _lastParsing = new ParseResponse();
    private CSVOptions _csvOptions = new CSVOptions();
    
    private StartParserProcessOptions _consoleAdvancedOptions = new StartParserProcessOptions();
    private static StartParserProcessOptions _consoleBaseStartOptions = new StartParserProcessOptions();
    private static StartParserProcessOptions _consoleBrowserOnlyOptions = new StartParserProcessOptions() { ConfigureBrowser = true };
    
    private bool isStartedConsole => saveData.Value.StartedConsoleId != null;
    private bool _isLastParseSuccess => _lastParsing.CurrentIndexUrl == _lastParsing.AllUrls.Count - 1;
    private int _progressPercent => _lastParsing.AllUrls.Count == 0
        ? 0
        : (int)Math.Round((_lastParsing.CurrentIndexUrl + 1) * 100.0 / _lastParsing.AllUrls.Count);

    private static readonly ConcurrentQueue<string> _consoleLogs = new();
    private const int MaxLogLines = 300;
    private Timer? _logRefreshTimer;

    private AllegroPublishService.DeviceFlowInfo? _deviceInfo;

    private string CategoriesBlackListText
    {
        get => string.Join(", ", _csvOptions.CategoriesBlackList);
        set => _csvOptions.CategoriesBlackList = value
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();
    }

    protected override void OnInitialized()
    {
        _logRefreshTimer = new Timer(_ => InvokeAsync(StateHasChanged), null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    protected override void OnParametersSet()
    {
        _lastParsing = SaverExtensions.LastParse.Read();
        _csvOptions = SaverExtensions.CSVOptions.Read();
    }

    public void Dispose()
    {
        _logRefreshTimer?.Dispose();
    }

    private void RegenerateCsv()
    {
        CSVMaker.MakeCSV(SaverExtensions.Products.Read().Values.ToList(),SaverExtensions.CSVOptions.Read());
        toastService.ShowSuccess("CSV regenerated successfully!");
    }

    private void SaveAllOptions()
    {
        try
        {
            saveData.Write();
            SaverExtensions.CSVOptions.Value = _csvOptions;
            SaverExtensions.CSVOptions.Write();
            allegro.SaveSettings();
            toastService.ShowSuccess("Options saved successfully!");
        }
        catch (Exception e)
        {
            toastService.ShowError(e.Message);
        }
    }

    private async Task ConnectAllegro()
    {
        try
        {
            _deviceInfo = await allegro.ConnectAsync();
            toastService.ShowInfo("Confirm the code on Allegro to finish connecting.");
        }
        catch (Exception e)
        {
            toastService.ShowError(e.Message);
        }
    }

    private async Task PublishToAllegro()
    {
        try
        {
            var updated = await allegro.PublishAsync();
            toastService.ShowSuccess($"Published: {updated} offers updated.");
        }
        catch (Exception e)
        {
            toastService.ShowError(e.Message);
        }
    }

    private void StartConsole(string pathDll,string args)
    {
        try
        {
            string workingDirectory = Path.GetDirectoryName(pathDll) ?? "";
            var process = new Process
            {
                StartInfo = new ProcessStartInfo()
                {
                    Arguments = $"\"{pathDll}\" {args}",
                    WorkingDirectory = workingDirectory,
                    FileName = "dotnet",
                    RedirectStandardOutput = true,
                    RedirectStandardError = true,
                    UseShellExecute = false,
                    CreateNoWindow = true,
                },
                EnableRaisingEvents = true,
            };
            process.OutputDataReceived += (_, e) => AppendLog(e.Data);
            process.ErrorDataReceived += (_, e) => AppendLog(e.Data);
            process.Exited += (_, _) => AppendLog("[console process exited]");

            if (process.Start())
            {
                process.BeginOutputReadLine();
                process.BeginErrorReadLine();
                saveData.Value.StartedConsoleId = process.Id.ToString();
                saveData.Write();
            }
        }
        catch(Exception e)
        {
            toastService.ShowError(e.Message);
        }
    }

    private static void AppendLog(string? line)
    {
        if (string.IsNullOrEmpty(line))
        {
            return;
        }
        _consoleLogs.Enqueue($"[{DateTime.Now:HH:mm:ss}] {line}");
        while (_consoleLogs.Count > MaxLogLines && _consoleLogs.TryDequeue(out _))
        {
        }
    }

    private void ClearLogs()
    {
        _consoleLogs.Clear();
    }

    private void StopConsole()
    {
        try
        {
            Process.Start("kill", saveData.Value.StartedConsoleId ?? "");
            saveData.Value.StartedConsoleId = null;
            saveData.Write();
        }
        catch(Exception e)
        {
            toastService.ShowError(e.Message);
        }
    }
    
    private class StartParserProcessOptions
    {
        public int StartIndex { get; set; } = 0;
        public bool ConfigureBrowser { get; set; } = false;
        public string ModeXml { get; set; } = "none";
        public bool IsUserStart { get; set; } = true;
        
        public string Args => 
            (StartIndex > 0 ? $"--start-index={StartIndex} " : "") +
            (ConfigureBrowser ? "--configure-browser " : "") +
            $"--mode-xml={ModeXml} " +
            (IsUserStart ? "--mode=manual " : "");
    }
}